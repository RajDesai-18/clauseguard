# ClauseGuard PRODUCTION environment template (single-box / Option 2).
#
# Copy to `.env` in the repo root ON THE VPS and fill in real values.
# NEVER commit the filled-in .env (it is gitignored). This template holds only
# placeholders and is safe to commit.
#
#   cp deploy/.env.prod.example .env
#   nano .env
#
# Generate strong secrets with:  openssl rand -hex 32

# ============================================================
# SECRETS YOU MUST SET
# ============================================================

# Backend app secret. The API refuses to boot in production if this is the
# default or under 32 chars (config.py guard). Generate: openssl rand -hex 32
APP_SECRET_KEY=

# Datastore credentials (replace the dev defaults clauseguard/secret, minioadmin).
POSTGRES_USER=clauseguard
POSTGRES_PASSWORD=
POSTGRES_DB=clauseguard

RABBITMQ_USER=clauseguard
RABBITMQ_PASSWORD=

MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# LLM keys (your real keys).
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Google OAuth (from Google Cloud Console). Used by Better Auth in the
# frontend container. The authorized redirect URI to register is:
#   https://clauseguard.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# PRODUCTION SETTINGS
# ============================================================

APP_ENV=production
CORS_ORIGINS=https://clauseguard.dev,https://www.clauseguard.dev

OTEL_ENABLED=true
OTEL_SERVICE_NAME=clauseguard
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

LLM_PRIMARY_MODEL=openai/gpt-5.1
LLM_FALLBACK_MODEL=gemini/gemini-2.5-flash

DB_ECHO=false

# ============================================================
# CONNECTION URLS -- LEAVE AS-IS (internal Docker network)
# ============================================================
# Do not use localhost. These are also set in docker-compose.prod.yml; kept
# here so the app has sane values if read directly from .env.
DATABASE_URL=postgresql+asyncpg://clauseguard:SET_VIA_COMPOSE@postgres:5432/clauseguard
RABBITMQ_URL=amqp://clauseguard:SET_VIA_COMPOSE@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=contracts
MINIO_USE_SSL=false

# Public backend origin (also baked into the frontend build).
NEXT_PUBLIC_API_URL=https://api.clauseguard.dev
NEXT_PUBLIC_BETTER_AUTH_URL=https://clauseguard.dev
