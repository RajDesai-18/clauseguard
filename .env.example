# Database
DATABASE_URL=postgresql+asyncpg://clauseguard:secret@localhost:5432/clauseguard

# RabbitMQ
RABBITMQ_URL=amqp://clauseguard:secret@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3)
MINIO_ENDPOINT=localhost:9000
