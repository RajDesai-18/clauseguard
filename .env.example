MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contracts
MINIO_USE_SSL=false

# LLM
OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder
