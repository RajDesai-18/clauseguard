LLM_FALLBACK_MODEL=claude-sonnet-4-20250514

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000